{
    "name": "data-product-portal-client",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "os": [
        "darwin",
        "linux"
    ],
    "scripts": {
        "build": "vite build",
        "build:prd": "vite build --mode production",
        "dev": "npm run copy-config && vite --force",
        "preview": "npm run copy-config && npm run build && vite preview",
        "test": "vitest",
        "test:run": "vitest run",
        "biome": "biome check --error-on-warnings && npm run typecheck && npm run validate-translations",
        "biome:fix": "biome check --write --error-on-warnings && npm run typecheck && npm run validate-translations",
        "biome:migrate": "biome migrate --write",
        "typecheck": "tsc --strict --noEmit",
        "extract-translations": "npx i18next-cli extract",
        "validate-translations": "npx i18next-cli extract --ci --dry-run",
        "lint-translations": "npx i18next-cli lint",
        "copy-config": "cp config.local.js public/config.js",
        "dep-viz": "npm run build && npx open-cli dependencies.html",
        "generate-api": "rm -rf src/store/api/services/generated/* && npx @rtk-query/codegen-openapi src/store/api/openapi-config.ts && node scripts/add-ts-nocheck.js",
        "knip": "knip"
    },
    "dependencies": {
        "@ant-design/charts": "^2.6.7",
        "@ant-design/icons": "^6.3.2",
        "@dagrejs/dagre": "^2.0.4",
        "@fontsource/inter": "^5.2.8",
        "@posthog/react": "^1.10.3",
        "@reduxjs/toolkit": "^2.12.0",
        "@tiptap/extension-heading": "^3.27.4",
        "@tiptap/extension-table": "^3.27.4",
        "@tiptap/extension-table-cell": "^3.27.4",
        "@tiptap/extension-table-header": "^3.27.4",
        "@tiptap/extension-table-row": "^3.27.4",
        "@tiptap/extension-text-style": "^3.27.4",
        "@tiptap/extension-typography": "^3.27.4",
        "@tiptap/pm": "^3.27.4",
        "@tiptap/react": "^3.27.4",
        "@tiptap/starter-kit": "^3.27.4",
        "@xyflow/react": "^12.11.2",
        "antd": "^6.5.1",
        "axios": "^1.18.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.4.0",
        "dayjs": "^1.11.21",
        "elkjs": "^0.11.1",
        "esbuild-runner": "^2.2.2",
        "framer-motion": "^12.42.2",
        "i18next": "^26.3.6",
        "i18next-http-backend": "^4.0.0",
        "js-sha256": "^0.11.1",
        "nuqs": "^2.9.0",
        "oidc-client-ts": "^3.5.0",
        "posthog-js": "^1.400.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-i18next": "^17.0.9",
        "react-oidc-context": "^3.3.1",
        "react-redux": "^9.3.0",
        "react-router": "^8.2.0",
        "react-syntax-highlighter": "^16.1.1",
        "use-debounce": "^10.1.1",
        "web-worker": "^1.5.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.4",
        "@rtk-query/codegen-openapi": "^2.0.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/react-syntax-highlighter": "^15.5.13",
        "@vitejs/plugin-react": "^6.0.3",
        "axios-mock-adapter": "^2.1.0",
        "esbuild": "^0.28.1",
        "i18next-cli": "^1.65.0",
        "jsdom": "^29.1.1",
        "knip": "^6.26.0",
        "msw": "^2.15.0",
        "rollup-plugin-visualizer": "^7.0.1",
        "sass": "^1.101.0",
        "typescript": "^7.0.2",
        "vite": "^8.1.4",
        "vite-plugin-svgr": "^5.2.0",
        "vitest": "^4.1.10"
    },
    "volta": {
        "node": "22.22.0"
    },
    "engines": {
        "node": ">= 22.0",
        "npm": ">= 11.11.0"
    },
    "overrides": {
        "i18next-parser": {
            "rimraf": "^4.0.0"
        },
        "zustand": {
            "use-sync-external-store": "^1.4.0"
        }
    }
}
